Algoritmo sin_titulo
		i= 42
		Escribir "Intenta adivinar el número secreto:"
		Leer u
		Mientras u <> i Hacer
			Si u < i Entonces
				Escribir "El numero secreto es mayor. Intenta de nuevo"
			Sino
				Escribir "El numero secreto es menor. Intenta de nuevo"
			FinSi
			Leer u
		FinMientras
		
		Escribir "Adivinaste el numero."
FinAlgoritmo
